APP_USER=admin
APP_PASS=yourpassword
SESSION_SECRET=change_this_to_a_long_random_string
# Tailscale auth key from https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxx
# SSH private key: paste full PEM content with literal \n between lines
# Example: -----BEGIN OPENSSH PRIVATE KEY-----\nAAAA...\n-----END OPENSSH PRIVATE KEY-----
SSH_PRIVATE_KEY=
PORT=3000
